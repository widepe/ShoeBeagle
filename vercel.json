{
  /*
    VERCEL CRON TIMEZONE NOTE (VERY IMPORTANT)

    Vercel cron runs in UTC (NOT California time).

    California time conversion:
    - PDT (Daylight Saving, ~March–Nov): UTC = Local + 7 hours
    - PST (Standard Time, ~Nov–March):   UTC = Local + 8 hours

    FORMULA:
    UTC time = California time + offset

    Examples:
    - 1:15 AM California (PDT) → 08:15 UTC  → "15 8 * * *"
    - 1:15 AM California (PST) → 09:15 UTC  → "15 9 * * *"

    ⚠️ IMPORTANT:
    - These cron times are currently set for PDT (UTC−7)
    - When DST ends, jobs will run 1 hour EARLIER unless adjusted
  */

  "crons": [
    { "path": "/api/scrapers/cheerio_scrapers", "schedule": "15 8 * * *" },

    { "path": "/api/scrapers/apify_scrapers", "schedule": "25 8 * * *" },

    { "path": "/api/scrapers/firecrawl_scrapers_1", "schedule": "35 8 * * *" },

    { "path": "/api/scrapers/firecrawl_scrapers_2", "schedule": "50 8 * * *" },

    { "path": "/api/scrapers/cheerio_scrapers_2", "schedule": "5 9 * * *" },

    { "path": "/api/scrapers/cheerio_scrapers_3", "schedule": "15 9 * * *" },

    { "path": "/api/scrapers/cheerio_scrapers_4", "schedule": "20 9 * * *" },

    { "path": "/api/merge-deals", "schedule": "25 9 * * *" },

    { "path": "/api/cron/check-alerts", "schedule": "30 9 * * *" }
  ]
}
